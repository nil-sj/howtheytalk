<article{{ attributes.addClass('node', 'node--type-language-entry') }}>
  <header class="node__header">
    <div class="node__meta">
      {% if content.field_main_category %}
        <span class="category-badge">{{ content.field_main_category }}</span>
      {% endif %}
      <span class="node__date">{{ node.createdtime|date('M j, Y') }}</span>
    </div>
    {{ title_prefix }}
    {% if not page %}
      <h2 class="node__title"><a href="{{ url }}" rel="bookmark">{{ label }}</a></h2>
    {% else %}
      <h1 class="node__title">{{ label }}</h1>
    {% endif %}
    {{ title_suffix }}
  </header>
  <div class="node__content">
    {% if content.field_short_meaning %}{{ content.field_short_meaning }}{% endif %}
    {% if content.field_detailed_explanation %}{{ content.field_detailed_explanation }}{% endif %}
    {% if content.field_usage_examples %}{{ content.field_usage_examples }}{% endif %}
    {% if content.field_notes_background %}{{ content.field_notes_background }}{% endif %}
    {% if content.field_tags %}{{ content.field_tags }}{% endif %}
    {% if content.field_source_links %}{{ content.field_source_links }}{% endif %}
    <div class="node__footer">
      <small class="node__updated">Last updated: {{ node.changedtime|date('F j, Y') }}</small>
    </div>
  </div>
</article>
