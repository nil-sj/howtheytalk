# TalkNotes Environment Variables
# Copy this to .env (dev) or .env.prod (production) and fill in real values.
# NEVER commit .env or .env.prod to git.

# ── PostgreSQL (your shared container) ───────────────────────────────────────
# This is the hostname of your postgres container on the shared Docker network.
# Run: docker inspect <your_postgres_container_name> | grep -i hostname
POSTGRES_HOST=postgres          # usually the container name or service name
POSTGRES_PORT=5432
POSTGRES_DB=talknotes           # the database you'll create in step below
POSTGRES_USER=talknotes_user    # dedicated user you'll create
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Drupal ───────────────────────────────────────────────────────────────────
# Generate with: drush php-eval 'echo \Drupal\Component\Utility\Crypt::randomBytesBase64(55);'
# Or:            openssl rand -base64 55
DRUPAL_HASH_SALT=CHANGE_ME_generate_a_random_string_at_least_55_chars_long

# ── Site URLs ─────────────────────────────────────────────────────────────────
SITE_URL=http://localhost:8090          # dev
# SITE_URL=https://talknotes.yourdomain.com  # production

TRUSTED_HOST=talknotes\.yourdomain\.com  # regex — for production settings.php

# ── AI Integration (Phase 5 — leave blank until ready) ───────────────────────
AI_API_KEY=
AI_PROVIDER=anthropic           # anthropic | openai
